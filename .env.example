# =============================================================================
# NetworkMemories — Metal Gear Online 1 (mgops-docker)
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.
# =============================================================================

# -----------------------------------------------------------------------------
# NETWORK
# -----------------------------------------------------------------------------
# Public IP of your server (reachable by PS2 clients)
SERVER_IP=YOUR_SERVER_IP

# -----------------------------------------------------------------------------
# PORTS — Java game server
# The Java server binds internally to ports 6731-6735.
# Docker exposes them externally as 5731-5735.
# PS2 clients connect to the external ports.
# -----------------------------------------------------------------------------
MGO1_PORT_AUTH=5731
MGO1_PORT_LOBBY=5732
MGO1_PORT_GAME1=5733
MGO1_PORT_GAME2=5734
MGO1_PORT_GAME3=5735

# Internal Java bind ports (offset +1000 to avoid conflicts)
MGO1_INTERNAL_AUTH=6731
MGO1_INTERNAL_LOBBY=6732
MGO1_INTERNAL_GAME1=6733
MGO1_INTERNAL_GAME2=6734
MGO1_INTERNAL_GAME3=6735

# -----------------------------------------------------------------------------
# DATABASE — MySQL / MariaDB
# -----------------------------------------------------------------------------
MYSQL_ROOT_PASSWORD=CHANGE_ME_ROOT_PASSWORD
MYSQL_DATABASE=mgops
MYSQL_USER=YOUR_DB_USERNAME
MYSQL_PASSWORD=CHANGE_ME_DB_PASSWORD
MYSQL_HOST=biomysql
MYSQL_PORT=3306

# -----------------------------------------------------------------------------
# WEB GATEWAY (Apache + PHP)
# Handles PS2 account management endpoints:
#   POST /us/mgs3/reguser/reguser.html  → account creation
#   POST /us/mgs3/deluser/deluser.html  → account deletion
#   POST /us/mgs3/chgpswd/chgpswd.html  → password change
# -----------------------------------------------------------------------------
GATEWAY_HTTP_PORT=80
GATEWAY_HTTPS_PORT=443

# -----------------------------------------------------------------------------
# DNS — dnsmasq
# Resolves *.konamionline.com → SERVER_IP for PS2 clients
# -----------------------------------------------------------------------------
DNS_PORT=53

# -----------------------------------------------------------------------------
# ADMIN PANEL
# -----------------------------------------------------------------------------
ADMIN_USER=admin
ADMIN_PASSWORD=CHANGE_ME_ADMIN_PASSWORD
ADMIN_SECRET=CHANGE_ME_RANDOM_SECRET_TOKEN

# -----------------------------------------------------------------------------
# LOGGING
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
